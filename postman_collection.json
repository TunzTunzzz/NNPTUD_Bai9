{
  "info": {
    "_postman_id": "nnptud-c6-auth-collection",
    "name": "NNPTUD-C6 Auth API",
    "description": "Collection test luồng: Đăng nhập → /me → Đổi mật khẩu → Đăng nhập lại bằng mật khẩu mới",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    },
    {
      "key": "token",
      "value": "",
      "type": "string",
      "description": "JWT token - tự động lưu sau khi đăng nhập"
    }
  ],
  "item": [
    {
      "name": "1. Đăng nhập (Login)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Kiểm tra status 200",
              "pm.test(\"Status 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Lưu token vào biến collection để dùng cho các request tiếp theo",
              "if (pm.response.code === 200) {",
              "    let token = pm.response.text();",
              "    pm.collectionVariables.set(\"token\", token);",
              "    console.log(\"✅ Token đã được lưu:\", token.substring(0, 30) + \"...\");",
              "}",
              "",
              "pm.test(\"Response trả về token (string)\", function () {",
              "    pm.expect(pm.response.text()).to.be.a('string');",
              "    pm.expect(pm.response.text().length).to.be.above(10);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"123456\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        },
        "description": "Đăng nhập bằng username + password. Token JWT (RS256) sẽ tự động được lưu vào biến {{token}} để dùng cho các bước tiếp theo."
      },
      "response": []
    },
    {
      "name": "2. Xem thông tin cá nhân (/me)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response là object user hợp lệ\", function () {",
              "    let json = pm.response.json();",
              "    pm.expect(json).to.be.an('object');",
              "    pm.expect(json).to.have.property('username');",
              "    pm.expect(json).to.have.property('email');",
              "    console.log(\"👤 User:\", json.username, \"|\", json.email);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "description": "Token JWT từ bước đăng nhập"
          }
        ],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "me"]
        },
        "description": "Lấy thông tin user đang đăng nhập. Yêu cầu Header: Authorization: Bearer {{token}}"
      },
      "response": []
    },
    {
      "name": "3. Đổi mật khẩu (Change Password)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "pm.test(\"Response xác nhận đổi mật khẩu thành công\", function () {",
              "    let json = pm.response.json();",
              "    pm.expect(json).to.have.property('message');",
              "    console.log(\"🔑\", json.message);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          },
          {
            "key": "Authorization",
            "value": "Bearer {{token}}",
            "description": "Token JWT từ bước đăng nhập"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"oldPassword\": \"123456\",\n    \"newPassword\": \"NewPassword@123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/change-password",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "change-password"]
        },
        "description": "Đổi mật khẩu. Cần truyền mật khẩu cũ (oldPassword) và mật khẩu mới (newPassword). Mật khẩu mới không được trùng mật khẩu cũ."
      },
      "response": []
    },
    {
      "name": "4. Đăng nhập lại bằng mật khẩu mới",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 200 OK - Đăng nhập thành công với mật khẩu mới\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "",
              "// Cập nhật token mới",
              "if (pm.response.code === 200) {",
              "    let newToken = pm.response.text();",
              "    pm.collectionVariables.set(\"token\", newToken);",
              "    console.log(\"✅ Token mới đã được cập nhật!\");",
              "}",
              "",
              "pm.test(\"Token mới hợp lệ\", function () {",
              "    pm.expect(pm.response.text()).to.be.a('string');",
              "    pm.expect(pm.response.text().length).to.be.above(10);",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"NewPassword@123\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        },
        "description": "Đăng nhập lại bằng mật khẩu mới sau khi đổi. Xác nhận rằng mật khẩu cũ (123456) đã không còn hoạt động và mật khẩu mới (NewPassword@123) đã có hiệu lực."
      },
      "response": []
    },
    {
      "name": "❌ Test: Login sai mật khẩu (403)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 403 - Từ chối khi sai mật khẩu\", function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "console.log(\"Response:\", pm.response.text());"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"username\": \"admin\",\n    \"password\": \"SaiMatKhau999\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/login",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "login"]
        },
        "description": "Test case đăng nhập với mật khẩu sai - kỳ vọng trả về HTTP 403."
      },
      "response": []
    },
    {
      "name": "❌ Test: /me không có token (403)",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status 403 - Từ chối khi không có token\", function () {",
              "    pm.response.to.have.status(403);",
              "});",
              "console.log(\"Response:\", pm.response.text());"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/api/v1/auth/me",
          "host": ["{{baseUrl}}"],
          "path": ["api", "v1", "auth", "me"]
        },
        "description": "Test case gọi /me không kèm Authorization header - kỳ vọng trả về HTTP 403."
      },
      "response": []
    }
  ]
}
